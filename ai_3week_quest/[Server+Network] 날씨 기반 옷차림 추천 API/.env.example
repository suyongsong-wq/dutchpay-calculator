# OpenWeatherMap API 키를 여기에 넣으세요.
#
# 발급 방법:
#   1) https://openweathermap.org/api  접속 → 무료 회원가입
#   2) 로그인 후 우측 상단 계정 메뉴 → "My API keys"
#   3) 기본 키를 복사해서 아래에 붙여넣기
#   (신규 키는 활성화까지 수십 분~2시간 정도 걸릴 수 있습니다.)
#
# 사용법:  이 파일을 .env 로 복사한 뒤 키를 채우세요 →  cp .env.example .env
# 주의:    .env 파일은 .gitignore에 등록되어 깃에 올라가지 않습니다. (키 유출 방지)

OPENWEATHER_API_KEY=여기에_발급받은_키를_넣으세요

# (선택) 포트 변경이 필요하면 주석 해제
# PORT=3000
